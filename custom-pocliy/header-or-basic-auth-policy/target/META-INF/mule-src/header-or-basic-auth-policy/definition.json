{
  "title": "Header OR Basic Auth Policy",
  "type": "object",
  "description": "Allows request when configured header OR valid Basic Auth is present.",
  "properties": {
    "headerName": {
      "title": "Header Name",
      "description": "Header required as alternative authentication",
      "type": "string",
      "default": "x-client-name"
    },
    "username": {
      "title": "User Name",
      "type": "string"
    },
    "password": {
      "title": "User Password",
      "type": "string",
      "@context": {
        "@characteristics": [
          "security:sensitive"
        ]
      }
    }
  },
  "required": [
    "headerName",
    "username",
    "password"
  ],
  "unevaluatedProperties": false,
  "@context": {
    "@vocab": "anypoint://vocabulary/policy.yaml#",
    "security": "anypoint://vocabulary/policy.yaml#"
  },
  "$id": "header-or-basic-auth-policy",
  "$schema": "https://json-schema.org/draft/2019-09/schema"
}