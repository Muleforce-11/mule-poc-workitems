<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xmlns:http-policy="http://www.mulesoft.org/schema/mule/http-policy"
      xsi:schemaLocation="
      http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
      http://www.mulesoft.org/schema/mule/http-policy http://www.mulesoft.org/schema/mule/http-policy/current/mule-http-policy.xsd">

    <http-policy:proxy name="{{{policyId}}}-header-or-basic-auth">
        <http-policy:source>

            <!-- Step 1: Read configurable custom header -->
            <set-variable
                variableName="clientHeader"
                value='#[attributes.headers["{{{headerName}}}"] default ""]'/>

            <!-- Step 2: Read Authorization header (case-insensitive) -->
            <set-variable
                variableName="authHeader"
                value='#[%dw 2.0
output text/plain
---
(attributes.headers filterObject ((v, k) ->
    lower(k as String) == "authorization")
).authorization default ""]'/>

            <!-- Step 3: Build expected Basic Auth token -->
            <set-variable
                variableName="expectedAuth"
                value='#[%dw 2.0
output text/plain
---
"Basic " ++ dw::core::Binaries::toBase64(
    ("{{{username}}}:{{{password}}}" as Binary {encoding: "UTF-8"})
)]'/>

            <!-- Step 4: OR logic -->
            <choice>
                <when expression='#[ 
                    !isEmpty(vars.clientHeader)
                    or
                    vars.authHeader == vars.expectedAuth
                ]'>
                    <http-policy:execute-next/>
                </when>

                <otherwise>
                    <set-payload
                        value='#[%dw 2.0
output application/json
---
{
    message: "Either {{{headerName}}} header OR valid Basic Auth is required"
}]'/>

                    <raise-error
                        type="CLIENT_SECURITY:UNAUTHORIZED"
                        description="Missing {{{headerName}}} header and invalid Basic Auth"/>
                </otherwise>
            </choice>

        </http-policy:source>
    </http-policy:proxy>
</mule>