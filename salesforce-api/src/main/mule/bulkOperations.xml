payload map (s) -> {
    Id: s.id,
    Name: s.name,
    Age__c: s.age,
    Email__c: s.email,
    Course__c: s.course,
    Student_Id__c: s.studentId
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<logger level="INFO" doc:name="Before Bulk Upadte" doc:id="c0553e94-4bb8-4ef1-8e7f-1da4b477db2d" message="Bulk Upadte Started"/>
		<salesforce:create-job-bulk-api-v2 doc:name="Bulk Update" doc:id="64d803a1-80f9-4d9f-940e-a4fc7557bec9" config-ref="Salesforce_Config1" objectType="Student__c" operation="update"/>
		<logger level="INFO" doc:name="After Bulk Update" doc:id="a63e1fd3-fdf1-4dca-a2cd-ec8e38b6bd40" message="Bulk Update Finished"/>
		<ee:transform doc:name="Final Output" doc:id="93b72c82-961e-4114-9b4c-08409e24f7b4">
			<ee:message>
				<ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    "createdDate": payload.createdDate,
    "id":payload.id,
    "state": if(payload.state == "InProgress") "Completed" else payload.state, 
    "operation":payload.operation,
    "object":payload.object
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
	</flow>
	<flow name="bulkUpsertFlow" doc:id="297376a1-7aa2-43d7-9281-bd31378d85dd" >
		<http:listener doc:name="Listener" doc:id="badbd7dd-3b4d-44f5-a47a-3f7f41f9dfa1" config-ref="HTTP_Listener_config" path="/bulkUpsert" allowedMethods="PUT"/>
		<ee:transform doc:name="CSV Request" doc:id="ff659400-0ace-4dff-8063-15716aa76762" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/csv header=true, lineSeparator="\n"
---
payload map (s) -> {
	Id: s.id,
    Student_Id__c: s.studentId,
    Name: s.name,
    Age__c: s.age,
    Email__c: s.email,
    Course__c: s.course
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<logger level="INFO" doc:name="Before Bulk Upsert" doc:id="2c0dc92c-e67d-4596-98ba-080fcac1fdbb" message="Bulk Upsert Started"/>
		<salesforce:create-job-bulk-api-v2 objectType="Student__c" operation="upsert" doc:name="Bulk Upsert" doc:id="6dbdd4d9-53b2-4382-b36f-9a38e3d3ee0a" config-ref="Salesforce_Config1" externalIdFieldName="Student_Id__c"/>
		<logger level="INFO" doc:name="After Bulk Upsert" doc:id="84efdbb0-ce25-4e3e-a3cd-6847c4d08f37" message="Bulk Upsert Finished"/>
		<ee:transform doc:name="Final Output" doc:id="40e47f08-94e2-47fc-94a9-60be3e4541a7" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
{
    "createdDate": payload.createdDate,
    "id":payload.id,
    
    "state": if(payload.state == "InProgress") "Completed" else payload.state, 
    "operation":payload.operation,
    "object":payload.object
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
	</flow>
	<flow name="bulkDeleteFlow" doc:id="5b7e79af-59da-407c-bdb3-abddd8cd9c7c" >
		<http:listener doc:name="Listener" doc:id="4b9444ff-6024-4ae4-9070-4f61c57e44d9" config-ref="HTTP_Listener_config" path="/bulkDelete" allowedMethods="DELETE"/>
