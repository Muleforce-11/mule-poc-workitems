    Id: s.id
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<logger level="INFO" doc:name="Before Bulk Delete" doc:id="d35bc483-553a-4c50-a59d-8671aa7e8367" message="Bulk Delete Started"/>
		<salesforce:create-job-bulk-api-v2 objectType="Student__c" operation="delete" doc:name="Bulk Delete" doc:id="d77aa57f-54a6-4c84-98b5-a8773f15a184" config-ref="Salesforce_Config1"/>
		<logger level="INFO" doc:name="After Bulk Delete" doc:id="1577a554-9a2e-47d5-a21a-0d1e1f62cfbe" message="Bulk Delete Finished"/>
		<ee:transform doc:name="Final Output" doc:id="04d6da6f-3270-4dd8-8f8c-a674470369de" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
{
    "createdDate": payload.createdDate,
    "id":payload.id,
    "state": if(payload.state == "InProgress") "Completed" else payload.state, 
    "operation":payload.operation,
    "object":payload.object
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
	</flow>
	<flow name="bulkInsertV1Flow" doc:id="3fb2a853-7285-4d05-883f-e34e89725a30" >
		<http:listener doc:name="Listener" doc:id="921b1966-6d7e-474b-b832-b70fdff24c99" config-ref="HTTP_Listener_config" path="/bulkInsertV1" allowedMethods="POST"/>
		<ee:transform doc:name="Java Request" doc:id="bff9568a-39dc-4f1e-b989-08d460f689c6" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/java
---
payload map (s) -> {
    Name: s.name,
    Age__c: s.age,
    Email__c: s.email,
    Course__c: s.course
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<logger level="INFO" doc:name="Before Bulk InsertV1" doc:id="af6ab7b8-6b7f-4e2e-bba1-85c4cdf1495b" message="Bulk Insert V1 started"/>
		<salesforce:create-job operation="insert" type="Student__c" doc:name="Create job" doc:id="91f84a2d-7d58-4161-b195-76d31e760d8b" config-ref="Salesforce_Config1" target="jobInfo"/>
		<salesforce:create-batch doc:name="Create batch" doc:id="fc123d37-1df1-49de-abed-a24685eca6dd" config-ref="Salesforce_Config1" target="batchInfo" jobInfoBatch="#[vars.jobInfo]"/>
		<salesforce:close-job doc:name="Close job" doc:id="b2c8f16a-4015-4e03-a48d-6a4a7f3d2109" config-ref="Salesforce_Config1" jobId="#[vars.jobInfo.id]"/>
		<ee:transform doc:name="Final Output" doc:id="b9769c01-03a9-4642-b423-fa92fa144317" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
{
    "createdDate": payload.createdDate,
    "id":payload.id,
    "state": if(payload.state == "InProgress") "Completed" else payload.state, 
    "operation":payload.operation,
    "object":payload.object
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
	</flow>
</mule>
