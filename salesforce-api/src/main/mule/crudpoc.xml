	<flow name="createcrudpocFlow" doc:id="4e56af0c-9f56-4cc6-a122-4808abde06dd" >
		<http:listener doc:name="Listener" doc:id="e4b9013e-9886-44d9-b738-5f9457bcf697" config-ref="HTTP_Listener_config" path="/students" allowedMethods="POST"/>
		<ee:transform doc:name="Transform Message" doc:id="390df9bf-6df9-48a6-8197-2111e0cf376d" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/java
---
payload map (item) -> {
  Name: item.name,
  Age__c: item.age,
  Course__c: item.course,
  Email__c: item.email
}
]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<salesforce:create doc:name="Create" doc:id="08b07850-f3a8-4174-b63d-085d7d85cb42" config-ref="Salesforce_Config" type="CHANNEL_ORDERS__System_Property__mdt"/>
