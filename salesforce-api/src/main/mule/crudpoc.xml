			<salesforce:salesforce-query ><![CDATA[SELECT Id, Name, Age__c, Course__c, Email__c FROM Student__c]]></salesforce:salesforce-query>
		</salesforce:query>
		<ee:transform doc:name="Transform Message" doc:id="a0517f75-4f92-4530-9bb1-0f702bff6960" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
payload map (item) -> {
  id: item.Id,
  name: item.Name,
  age: item.Age__c,
  course: item.Course__c,
  email: item.Email__c
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
	</flow>
